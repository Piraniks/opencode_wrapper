{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "default_agent": "dev-orchestrator",
  "agent": {
    "dev-coder": {
      "model": "opencode/big-pickle"
    },
    "dev-test-writer": {
      "model": "opencode/big-pickle"
    },
    "dev-reviewer": {
      "model": "opencode/big-pickle"
    }
  },
  "permission": {
    "bash": {
      "*": "ask",

      "cat *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "cd *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "mv *": "allow",
      "wc*": "allow",
      "uniq*": "allow",
      "xargs *": "allow",
      "tee*": "allow",
      "file*": "allow",
      "which*": "allow",

      "rm *": "allow",
      "rm -rf .*": "deny",
      "rm -r .*": "deny",
      "rm .*": "deny",
      "rm */.*": "deny",

      "ls *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "cp *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "sed *": "allow",
      "awk *": "allow",
      "sort *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "diff *": "allow",

      "curl *": "allow",
      "wget *": "allow",

      "git log*": "allow",
      "git diff*": "allow",
      "git status*": "allow",
      "git show*": "allow",

      "docker ps*": "allow",
      "docker images*": "allow",
      "docker exec*": "allow",
      "docker run*": "allow",
      "docker stop*": "allow",
      "docker rm*": "allow",
      "docker rmi*": "allow",
      "docker image *": "allow",
      "docker container *": "allow",
      "docker network *": "allow",
      "docker build *": "allow",
      "docker compose *": "allow",
      "docker system *": "allow",

      "python *": "allow",
      "python3 *": "allow",
      "node *": "allow",

      "uv run*": "allow",
      "uv remove*": "allow",
      "uv sync*": "allow",
      "uv lock*": "allow",

      "poetry run*": "allow",
      "poetry remove*": "allow",
      "poetry lock*": "allow",
      "poetry sync*": "allow",

      "npm *": "deny",

      "make *": "allow"
    },
    "webfetch": "allow"
  }
}
